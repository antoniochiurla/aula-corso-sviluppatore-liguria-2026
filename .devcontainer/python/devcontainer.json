{
  "name": "Corso Chiurla",
  "dockerComposeFile": "../../docker/python-docker-compose.yml",
  "service": "app-dev",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions":[
        "mhutchie.git-graph",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "lang2hong.db-client"
      ]
    },
  "settings": {
        "python.createEnvironment.trigger": "off",
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false,
        "extensions.ignoreRecommendations": true
  }
 },
 "postStartCommand": "pip install -r docker/requirements.txt"
}