@startuml
left to right direction
actor "Utente" as U

package "TaMaSy (Task Management System)" {
  usecase "Visualizza Elenco Task" as UC1
  usecase "Aggiungi Task" as UC2
  usecase "Modifica Task (Correzione)" as UC3
  usecase "Rimuovi Task" as UC4
  usecase "Cambia Stato (Toggle)" as UC5
  usecase "Salva su File" as UC6
  usecase "Carica da File" as UC7
}

U --> UC1
U --> UC2
U --> UC3
U --> UC4
U --> UC5

UC1 ..> UC7 : <<include>>
UC2 ..> UC6 : <<include>>
UC3 ..> UC6 : <<include>>
UC4 ..> UC6 : <<include>>
UC5 ..> UC6 : <<include>>

note right of UC6
  Il salvataggio avviene
  automaticamente dopo
  ogni modifica.
end note
@enduml